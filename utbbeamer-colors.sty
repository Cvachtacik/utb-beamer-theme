% =================================================
% General document colours
% =================================================

\setbeamercolor{background canvas}{bg=UTBWhite}
\setbeamercolor{normal text}{fg=UTBDark,bg=UTBWhite}
\setbeamercolor{structure}{fg=UTBPrimary}

% =================================================
% Beamer palettes
% =================================================

\setbeamercolor{palette primary}{fg=UTBDark,bg=UTBPrimary}
\setbeamercolor{palette secondary}{fg=UTBDark,bg=UTBPrimary}
\setbeamercolor{palette tertiary}{fg=UTBDark,bg=UTBPrimary}
\setbeamercolor{palette quaternary}{fg=UTBDark,bg=UTBPrimary}

\setbeamercolor{palette sidebar primary}{fg=UTBDark,bg=UTBPrimary}
\setbeamercolor{palette sidebar secondary}{fg=UTBDark,bg=UTBPrimary}
\setbeamercolor{palette sidebar tertiary}{fg=UTBDark,bg=UTBPrimary}
\setbeamercolor{palette sidebar quaternary}{fg=UTBDark,bg=UTBPrimary}

% =================================================
% Header / footer navigation
% =================================================

\setbeamercolor{section in head/foot}{fg=UTBDark,bg=UTBPrimary}
\setbeamercolor{subsection in head/foot}{fg=UTBDark,bg=UTBPrimary}

\setbeamercolor{author in head/foot}{fg=UTBDark,bg=UTBPrimary}
\setbeamercolor{title in head/foot}{fg=UTBDark,bg=UTBPrimary}
\setbeamercolor{date in head/foot}{fg=UTBDark,bg=UTBPrimary}

% =================================================
% Titles
% =================================================

\setbeamercolor{title}{fg=UTBPrimary,bg=UTBWhite}
\setbeamercolor{subtitle}{fg=UTBSecondary,bg=UTBWhite}

\setbeamercolor{frametitle}{fg=UTBDark,bg=UTBPrimary}
\setbeamercolor{framesubtitle}{fg=UTBSecondary,bg=UTBPrimary}

\setbeamercolor{titlelike}{fg=UTBPrimary,bg=UTBWhite}

% =================================================
% Table of contents
% =================================================

\setbeamercolor{section in toc}{fg=UTBPrimary,bg=UTBWhite}
\setbeamercolor{subsection in toc}{fg=UTBSecondary,bg=UTBWhite}
\setbeamercolor{section number projected}{fg=UTBDark,bg=UTBPrimary}
\setbeamercolor{subsection number projected}{fg=UTBDark,bg=UTBSecondary}

% =================================================
% Items, bullets, enumeration
% =================================================

\setbeamercolor{item}{fg=UTBPrimary}
\setbeamercolor{subitem}{fg=UTBSecondary}
\setbeamercolor{subsubitem}{fg=UTBAccent}

\setbeamercolor{enumerate item}{fg=UTBPrimary}
\setbeamercolor{enumerate subitem}{fg=UTBSecondary}
\setbeamercolor{enumerate subsubitem}{fg=UTBAccent}

\setbeamercolor{item projected}{fg=UTBDark,bg=UTBPrimary}
\setbeamercolor{subitem projected}{fg=UTBDark,bg=UTBSecondary}
\setbeamercolor{subsubitem projected}{fg=UTBWhite,bg=UTBAccent}

% =================================================
% Blocks
% Keep the Beamer look, only recolour.
% =================================================

\setbeamercolor{block title}{fg=UTBDark,bg=UTBPrimary}
\setbeamercolor{block body}{fg=UTBDark,bg=UTBSoft!35!white}

% Alert = use official contrast/accent colour
\setbeamercolor{block title alerted}{fg=UTBWhite,bg=UTBAccent}
\setbeamercolor{block body alerted}{fg=UTBDark,bg=UTBAccent!10!white}
\setbeamercolor{alerted text}{fg=UTBAccent}

% Example = use secondary complementary colour
\setbeamercolor{block title example}{fg=UTBWhite,bg=UTBSecondary}
\setbeamercolor{block body example}{fg=UTBDark,bg=UTBSecondary!10!white}
\setbeamercolor{example text}{fg=UTBSecondary}

% =================================================
% Bibliography / captions / buttons
% =================================================

\setbeamercolor{bibliography item}{fg=UTBPrimary}
\setbeamercolor{bibliography entry author}{fg=UTBDark}
\setbeamercolor{bibliography entry title}{fg=UTBPrimary}
\setbeamercolor{bibliography entry location}{fg=UTBSecondary}
\setbeamercolor{bibliography entry note}{fg=UTBSecondary}

\setbeamercolor{caption name}{fg=UTBPrimary}

\setbeamercolor{button}{fg=UTBDark,bg=UTBPrimary}
\setbeamercolor{button border}{fg=UTBPrimary}

% =================================================
% Separation lines / sidebar
% =================================================

\setbeamercolor{separation line}{bg=UTBPrimary}
\setbeamercolor{upper separation line head}{bg=UTBPrimary}
\setbeamercolor{middle separation line head}{bg=UTBPrimary}
\setbeamercolor{lower separation line head}{bg=UTBPrimary}

\setbeamercolor{upper separation line foot}{bg=UTBPrimary}
\setbeamercolor{middle separation line foot}{bg=UTBPrimary}
\setbeamercolor{lower separation line foot}{bg=UTBPrimary}

\setbeamercolor{sidebar}{fg=UTBDark,bg=UTBPrimary}
\setbeamercolor{sidebar left}{fg=UTBDark,bg=UTBPrimary}
\setbeamercolor{sidebar right}{fg=UTBDark,bg=UTBPrimary}

% =================================================
% Theorem-like environments
% =================================================

\setbeamercolor{theorem title}{fg=UTBDark,bg=UTBPrimary}
\setbeamercolor{theorem body}{fg=UTBDark,bg=UTBSoft!35!white}

% =================================================
% Mini frame navigation
% =================================================

\setbeamercolor{mini frame}{fg=UTBDark,bg=UTBPrimary}
\setbeamercolor{mini frame in current subsection}{fg=UTBWhite,bg=UTBAccent}
\setbeamercolor{mini frame in other subsection}{fg=UTBDark,bg=UTBSoft}

% =================================================
% FT zmena textu
% =================================================

\ifdefstring{\utb@faculty}{ft}{%
	
	% Header / footer
	\setbeamercolor{section in head/foot}{fg=UTBWhite,bg=UTBPrimary}
	\setbeamercolor{subsection in head/foot}{fg=UTBWhite,bg=UTBPrimary}
	
	\setbeamercolor{author in head/foot}{fg=UTBWhite,bg=UTBPrimary}
	\setbeamercolor{title in head/foot}{fg=UTBWhite,bg=UTBPrimary}
	\setbeamercolor{date in head/foot}{fg=UTBWhite,bg=UTBPrimary}
	
	% Palettes
	\setbeamercolor{palette primary}{fg=UTBWhite,bg=UTBPrimary}
	\setbeamercolor{palette secondary}{fg=UTBWhite,bg=UTBPrimary}
	\setbeamercolor{palette tertiary}{fg=UTBWhite,bg=UTBPrimary}
	\setbeamercolor{palette quaternary}{fg=UTBWhite,bg=UTBPrimary}
	
	% Frame titles
	\setbeamercolor{frametitle}{fg=UTBWhite,bg=UTBPrimary}
	
	% Blocks
	\setbeamercolor{block title}{fg=UTBWhite,bg=UTBPrimary}
	
}{}

% =================================================
% FHS zmena textu
% =================================================

\ifdefstring{\utb@faculty}{fhs}{%
	
	% Header / footer
	\setbeamercolor{section in head/foot}{fg=UTBWhite,bg=UTBPrimary}
	\setbeamercolor{subsection in head/foot}{fg=UTBWhite,bg=UTBPrimary}
	
	\setbeamercolor{author in head/foot}{fg=UTBWhite,bg=UTBPrimary}
	\setbeamercolor{title in head/foot}{fg=UTBWhite,bg=UTBPrimary}
	\setbeamercolor{date in head/foot}{fg=UTBWhite,bg=UTBPrimary}
	
	% Palettes
	\setbeamercolor{palette primary}{fg=UTBWhite,bg=UTBPrimary}
	\setbeamercolor{palette secondary}{fg=UTBWhite,bg=UTBPrimary}
	\setbeamercolor{palette tertiary}{fg=UTBWhite,bg=UTBPrimary}
	\setbeamercolor{palette quaternary}{fg=UTBWhite,bg=UTBPrimary}
	
	% Frame titles
	\setbeamercolor{frametitle}{fg=UTBWhite,bg=UTBPrimary}
	
	% Blocks
	\setbeamercolor{block title}{fg=UTBWhite,bg=UTBPrimary}
	
}{}

